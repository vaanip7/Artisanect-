// Artisanect — Prisma schema (Week 6: added Google OAuth fields)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  CRAFTER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?  // nullable — Google OAuth users have no password
  googleId  String?  @unique // Google OAuth subject ID
  role      Role
  craft     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products      Product[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]

  @@index([role])
  @@map("users")
}

model Product {
  id               Int      @id @default(autoincrement())
  title            String
  category         String
  description      String
  price            Float
  rating           Float    @default(0)
  stock            Int      @default(0)
  image            String
  images           String[]
  materials        String[]
  tags             String[]
  dimensions       String?
  deliveryEstimate String?
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  crafterId String
  crafter   User   @relation(fields: [crafterId], references: [id], onDelete: Cascade)

  cartItems     CartItem[]
  wishlistItems WishlistItem[]

  @@index([category])
  @@index([crafterId])
  @@map("products")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}
